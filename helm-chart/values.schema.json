{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "dynamic-zones-api values",
  "type": "object",
  "additionalProperties": false,
  "required": ["dynamicZonesAPI", "auth", "powerDNS", "ingress"],
  "properties": {
    "dynamicZonesAPI": {
      "type": "object",
      "additionalProperties": false,
      "required": ["image", "version", "hostname", "replicas", "database", "dnsPolicy"],
      "properties": {
        "image": { "type": "string", "minLength": 1 },
        "imagePullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] },
        "version": { "type": "string", "minLength": 1 },
        "hostname": { "type": "string", "minLength": 1 },
        "replicas": { "type": "integer", "minimum": 0 },
        "existingSecret": { "type": "string" },
        "apiMode": { "type": "string", "enum": ["production", "development"] },
        "initialDataProviderScript": { "type": "string" },
        "apiTokenTtlHours": { "type": "integer", "minimum": 1 },
        "apiBindString": { "type": "string" },
        "apiBaseUrl": { "type": "string" },
        "upstreamDNS": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "server": { "type": "string" },
            "port": { "type": "integer" },
            "tsigName": { "type": "string" },
            "tsigAlgorithm": { "type": "string" },
            "tsigSecret": { "type": "string" },
            "zone": { "type": "string" },
            "name": { "type": "string" },
            "ttl": { "type": "integer" },
            "updateInterval": { "type": "integer" }
          }
        },
        "database": {
          "type": "object",
          "additionalProperties": false,
          "required": ["type"],
          "properties": {
            "type": { "type": "string", "enum": ["postgres", "memory"] },
            "name": { "type": "string" },
            "username": { "type": "string" },
            "password": { "type": "string" },
            "hostname": { "type": "string" },
            "connectionString": { "type": "string" }
          }
        },
        "dnsPolicy": {
          "type": "object",
          "additionalProperties": false,
          "required": ["superAdminEmails"],
          "properties": {
            "superAdminEmails": {
              "type": "array",
              "items": { "type": "string", "format": "email" }
            }
          }
        },
        "zoneDefaults": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "defaultAdminTsigKeyName": { "type": "string" },
            "defaultAdminTsigKey": { "type": "string" },
            "defaultAdminTsigAlg": { "type": "string" },
            "defaultRecords": { "type": "string" }
          }
        }
      }
    },
    "selfServiceUI": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "hostname": { "type": "string" }
      }
    },
    "auth": {
      "type": "object",
      "additionalProperties": false,
      "required": ["oidc"],
      "properties": {
        "provider": { "type": "string" },
        "oidc": {
          "type": "object",
          "additionalProperties": false,
          "required": ["issuerUrl", "clientId"],
          "properties": {
            "issuerUrl": { "type": "string", "minLength": 1 },
            "clientId": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "powerDNS": {
      "type": "object",
      "additionalProperties": false,
      "required": ["apiKey", "apiUrl"],
      "properties": {
        "apiKey": { "type": "string" },
        "apiUrl": { "type": "string" },
        "vhost": { "type": "string" },
        "logLevel": { "type": "integer" },
        "server": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "ip": { "type": "string" },
            "port": { "type": "integer" },
            "advertisedNameserver": { "type": "string" }
          }
        }
      }
    },
    "ingress": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled"],
      "properties": {
        "enabled": { "type": "boolean" },
        "className": { "type": "string" },
        "annotations": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    }
  }
}
